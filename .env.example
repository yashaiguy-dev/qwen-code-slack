# ── Slack Tokens (Socket Mode — no public URL needed) ──
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-app-level-token

# ── Optional ──
# Comma-separated Slack user IDs (leave empty = anyone can use it)
AUTHORIZED_USERS=

# Working directory for Qwen Code sessions
QWEN_WORK_DIR=~/qwen-workspace

# Timeout in seconds (default: 300 = 5 minutes)
QWEN_TIMEOUT=300
